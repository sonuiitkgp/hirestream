// ─── HireStream Prisma Schema ────────────────────────────────────────────────

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  JOB_SEEKER
  RECRUITER
  ADMIN
}

enum Visibility {
  PUBLIC
  PRIVATE
  HIDDEN
}

enum CommentStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum SectionType {
  EXPERIENCE
  PROJECT
  INTERNSHIP
  ACADEMIC
  EXTRA_CURRICULAR
  CODECHEF
}

enum NotificationType {
  NEW_MESSAGE
  NEW_COMMENT
  COMMENT_ACCEPTED
  COMMENT_DECLINED
  COMMENT_REPLY
  NEW_SUGGESTION
  SUGGESTION_ACCEPTED
  SUGGESTION_DECLINED
  PROFILE_VIEW
  NEW_USER
}

// ── Auth tables (NextAuth v5 required) ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ── Core User ─────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed — null for OAuth users
  role          Role      @default(JOB_SEEKER)   // active role
  roles         Role[]    @default([JOB_SEEKER])  // all granted roles
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Profile (job seekers)
  profile Profile?

  // Recruiter relations
  postedJobs             Job[]
  sentMessages           Message[]      @relation("MessageSender")
  recruiterConversations Conversation[] @relation("RecruiterConversations")
  candidateConversations Conversation[] @relation("CandidateConversations")

  // Peer review
  comments Comment[] @relation("CommentAuthor")

  // Suggestions
  suggestions Suggestion[] @relation("SuggestionAuthor")

  // Resume uploads
  resumeUploads ResumeUpload[]

  // Notifications
  notifications     Notification[] @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationActor")
}

// ── Profile (Job Seeker) ──────────────────────────────────────────────────────

model Profile {
  id         String     @id @default(cuid())
  userId     String     @unique
  bio        String?    @db.Text
  headline   String?
  location   String?
  website    String?
  linkedin   String?
  github     String?
  visibility Visibility @default(PUBLIC)
  shareToken String     @unique @default(cuid())
  miscData   Json?      // misc resume sections: [{ title: string, items: string[] }]

  // pgvector embedding (768-dim for text-embedding-004)
  embedding Unsupported("vector(768)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Section tables
  experiences      Experience[]
  projects         Project[]
  internships      Internship[]
  academicBgs      AcademicBackground[]
  extraCurriculars ExtraCurricular[]
  codechefProfile  CodeChefProfile?

  // Comments on this profile
  comments    Comment[]
  suggestions Suggestion[]
}

// ── Profile Sections ──────────────────────────────────────────────────────────

model Experience {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text
  location    String?
  createdAt   DateTime  @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("ExperienceComments")
}

model Project {
  id          String    @id @default(cuid())
  profileId   String
  name        String
  description String?   @db.Text
  techStack   String[]
  url         String?
  repoUrl     String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("ProjectComments")
}

model Internship {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text
  location    String?
  stipend     String?
  createdAt   DateTime  @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("InternshipComments")
}

model AcademicBackground {
  id          String   @id @default(cuid())
  profileId   String
  institution String
  degree      String
  field       String
  startYear   Int
  endYear     Int?
  gpa         Float?
  current     Boolean  @default(false)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("AcademicComments")
}

model ExtraCurricular {
  id          String    @id @default(cuid())
  profileId   String
  activity    String
  role        String?
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("ExtraCurricularComments")
}

model CodeChefProfile {
  id          String   @id @default(cuid())
  profileId   String   @unique
  username    String
  rating      Int?
  maxRating   Int?
  globalRank  Int?
  countryRank Int?
  solved      Int?
  stars       String?
  updatedAt   DateTime @default(now())

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  comments Comment[] @relation("CodeChefComments")
}

// ── Peer Review / Comments ────────────────────────────────────────────────────

model Comment {
  id             String        @id @default(cuid())
  profileId      String
  authorId       String
  sectionType    SectionType
  // optional FK to specific section item
  experienceId   String?
  projectId      String?
  internshipId   String?
  academicId     String?
  extraCurId     String?
  codechefId     String?
  // content & threading
  content        String        @db.Text
  parentId       String?
  highlightStart Int?
  highlightEnd   Int?
  status         CommentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  profile         Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  author          User                @relation("CommentAuthor", fields: [authorId], references: [id])
  parent          Comment?            @relation("CommentThread", fields: [parentId], references: [id])
  replies         Comment[]           @relation("CommentThread")
  history         CommentHistory[]
  experience      Experience?         @relation("ExperienceComments", fields: [experienceId], references: [id])
  project         Project?            @relation("ProjectComments", fields: [projectId], references: [id])
  internship      Internship?         @relation("InternshipComments", fields: [internshipId], references: [id])
  academic        AcademicBackground? @relation("AcademicComments", fields: [academicId], references: [id])
  extraCurricular ExtraCurricular?    @relation("ExtraCurricularComments", fields: [extraCurId], references: [id])
  codechef        CodeChefProfile?    @relation("CodeChefComments", fields: [codechefId], references: [id])
}

model CommentHistory {
  id              String   @id @default(cuid())
  commentId       String
  previousContent String   @db.Text
  editedAt        DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

// ── Inline Suggestions ──────────────────────────────────────────────────────

model Suggestion {
  id            String        @id @default(cuid())
  profileId     String
  authorId      String
  sectionType   SectionType
  sectionItemId String?
  fieldName     String
  originalText  String        @db.Text
  suggestedText String        @db.Text
  startOffset   Int?
  endOffset     Int?
  status        CommentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  author  User    @relation("SuggestionAuthor", fields: [authorId], references: [id])
}

// ── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String?          // who triggered it (null for system notifications)
  type        NotificationType
  title       String
  body        String?
  // Link to the relevant resource
  linkUrl     String?          // e.g. "/mailbox/abc", "/profile/comments"
  // Optional references for grouping/dedup
  resourceId  String?          // ID of the comment, suggestion, message, etc.
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
}

// ── Messaging / Mailbox ───────────────────────────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  jobId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiter User      @relation("RecruiterConversations", fields: [recruiterId], references: [id])
  candidate User      @relation("CandidateConversations", fields: [candidateId], references: [id])
  job       Job?      @relation(fields: [jobId], references: [id])
  messages  Message[]

  @@unique([recruiterId, candidateId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])
}

// ── Jobs ─────────────────────────────────────────────────────────────────────

model Job {
  id           String   @id @default(cuid())
  recruiterId  String
  title        String
  description  String   @db.Text
  requirements String[]
  location     String?
  remote       Boolean  @default(false)
  salaryMin    Int?
  salaryMax    Int?
  isActive     Boolean  @default(true)
  embedding    Unsupported("vector(768)")?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  recruiter     User           @relation(fields: [recruiterId], references: [id])
  conversations Conversation[]
}

// ── Resume Uploads ────────────────────────────────────────────────────────────

model ResumeUpload {
  id          String    @id @default(cuid())
  userId      String
  fileUrl     String
  fileName    String
  parsedData  Json?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
